{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "start": {
        "dependsOn": ["build"],
        "persistent": true,
        "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}